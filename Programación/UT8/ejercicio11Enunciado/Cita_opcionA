import java.time.LocalDate;

public class Cita {

    private LocalDate fecha;
    private String descripcion;

    public Cita(LocalDate fecha, String descripcion) throws CitaInvalidaException {

        if (fecha == null) {
            throw new CitaInvalidaException("La fecha no puede ser null");
        }

        if (fecha.isBefore(LocalDate.now())) {
            throw new CitaInvalidaException("No se permiten fechas pasadas");
        }

        if (descripcion == null || descripcion.isBlank()) {
            throw new CitaInvalidaException("La descripción no puede estar vacía");
        }

        this.fecha = fecha;
        this.descripcion = descripcion;
    }

    public LocalDate getFecha() {
        return fecha;
    }

    public String getDescripcion() {
        return descripcion;
    }

    @Override
    public String toString() {
        return fecha + " - " + descripcion;
    }
}
